{
  "version": 2,
  "functions": {
    "api/chat.js": { "memory": 512, "maxDuration": 30 },
    "api/pdf.js":  { "memory": 512, "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/pdf",  "dest": "/api/pdf.js"  },
    { "src": "/(.*)",     "dest": "/public/$1"    }
  ]
}
